{
  "name": "RegMind-CA-Screening-Observability",
  "namespace": "RegMind/Screening/ComplyAdvantage",
  "logGroups": {
    "operational": "/regmind/ca/operational/",
    "audit": "/regmind/ca/audit/"
  },
  "widgets": [
    {
      "title": "CA Webhook Intake",
      "type": "log",
      "queryFile": "ca_webhook_intake.cwlogs",
      "metrics": ["WebhookDeliveries", "WebhookSignatureFailures", "WebhookMalformedPayloads", "WebhookUnknownEvents"]
    },
    {
      "title": "Webhook Background Processing",
      "type": "log",
      "queryFile": "ca_processing_latency.cwlogs",
      "metrics": ["WebhookProcessingLatencyMs", "WebhookStepLatencyMs", "WebhookAsyncProcessingFailures"]
    },
    {
      "title": "CA API and OAuth Health",
      "type": "log",
      "queryFile": "ca_api_health.cwlogs",
      "metrics": ["CaApiRequests", "CaApiLatencyMs", "CaAuthRequests", "CaAuthLatencyMs", "CaTokenCacheHits", "CaTokenCacheMisses"]
    },
    {
      "title": "Storage, Subscription, and Agent 7",
      "type": "log",
      "queryFile": "ca_storage_agent7.cwlogs",
      "metrics": ["NormalizedWriteFailures", "NormalizedWriteSuccesses", "MonitoringAlertsWriteFailures", "MonitoringAlertsWriteSuccesses", "SubscriptionUpdateFailures", "SubscriptionUpdateSuccesses", "Agent7PushFailures", "Agent7PushSkipped"]
    }
  ]
}
