# ── Database (contains client data — never commit) ──
*.db
*.db-shm
*.db-wal

# ── Environment & secrets ──
.env
.env.*

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── Node ──
node_modules/
package-lock.json

# ── Uploads (user documents — never commit) ──
arie-backend/uploads/

# ── OS files ──
.DS_Store
Thumbs.db
.fuse_hidden*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Test coverage ──
.coverage
.coverage.*
htmlcov/

# ── Database journals ──
*.db-journal

# ── Temp files ──
~$*
*.b64
transfer.html
arie-backend/=2.0.0

# ── Build/generator scripts (not product code) ──
scripts/

# ── Archive (old ARIE-branded files) ──
archive/
arie-backend/arie.db.bak_e2e

# ── Worktrees (managed by Claude Code) ──
.claude/worktrees/

# ── Lock files ──
.~lock.*
~$*

# ── Zip archives ──
*.zip

# ── Credentials (never commit) ──
Credentials.docx

# ── Pytest cache ──
.pytest_cache/

# ── Frontend HTML copies in backend dir (source of truth is repo root) ──
# These are copied at build time by CI/CD workflows and Render buildCommand
arie-backend/arie-portal.html
arie-backend/arie-backoffice.html
